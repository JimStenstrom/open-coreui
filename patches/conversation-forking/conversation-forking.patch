+	const forkConversation = async (messageId: string) => {
+		if ($temporaryChatEnabled) {
+			toast.error($i18n.t('Cannot fork a temporary chat'));
+			return;
+		}
+
+		try {
+			// Build the forked history - include all messages up to and including the fork point
+			const forkedMessages = {};
+			const message = history.messages[messageId];
+
+			if (!message) {
+				toast.error($i18n.t('Message not found'));
+				return;
+			}
+
+			// Traverse from the fork point back to the root to get all ancestor messages
+			let currentMessage = message;
+			const messageIds: string[] = [];
+
+			while (currentMessage) {
+				messageIds.unshift(currentMessage.id);
+				currentMessage = currentMessage.parentId ? history.messages[currentMessage.parentId] : null;
+			}
+
+			// Create new message IDs for the forked conversation
+			const oldToNewIdMap: Record<string, string> = {};
+			messageIds.forEach(id => {
+				oldToNewIdMap[id] = uuidv4();
+			});
+
+			// Build the forked messages with new IDs
+			for (const oldId of messageIds) {
+				const originalMsg = history.messages[oldId];
+				const newId = oldToNewIdMap[oldId];
+				const newParentId = originalMsg.parentId ? oldToNewIdMap[originalMsg.parentId] : null;
+
+				// For the last message (fork point), set childrenIds to empty
+				// For other messages, map the child that's in our chain
+				let newChildrenIds: string[] = [];
+				if (oldId !== messageId) {
+					// Find which child is in our chain (guard against undefined childrenIds)
+					const childInChain = (originalMsg.childrenIds ?? []).find(childId => messageIds.includes(childId));
+					if (childInChain) {
+						newChildrenIds = [oldToNewIdMap[childInChain]];
+					}
+				}
+
+				forkedMessages[newId] = {
+					...JSON.parse(JSON.stringify(originalMsg)),
+					id: newId,
+					parentId: newParentId,
+					childrenIds: newChildrenIds
+				};
+			}
+
+			const newCurrentId = oldToNewIdMap[messageId];
+			const forkedHistory = {
+				messages: forkedMessages,
+				currentId: newCurrentId
+			};
+
+			// Generate title for the forked chat
+			const firstUserMessage = Object.values(forkedMessages).find(
+				(m: any) => m.role === 'user'
+			) as any;
+			const forkTitle = firstUserMessage?.content
+				? `${$i18n.t('Fork')}: ${firstUserMessage.content.slice(0, 30)}${firstUserMessage.content.length > 30 ? '...' : ''}`
+				: `${$i18n.t('Fork')}: ${$chatTitle || $i18n.t('New Chat')}`;
+
+			// Create the new chat
+			const newChat = await createNewChat(
+				localStorage.token,
+				{
+					title: forkTitle,
+					models: selectedModels,
+					history: forkedHistory,
+					messages: createMessagesList(forkedHistory, forkedHistory.currentId),
+					timestamp: Date.now()
+				},
+				null
+			);
+
+			if (newChat) {
+				toast.success($i18n.t('Conversation forked successfully'));
+
+				// Update the chat list
+				currentChatPage.set(1);
+				await chats.set(await getChatList(localStorage.token, $currentChatPage));
+
+				// Navigate to the new chat
+				await goto(`/c/${newChat.id}`);
+			}
